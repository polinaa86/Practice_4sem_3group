TELEGRAM_BOT_TOKEN=8376010494:AAH1sB8QRVi7bRIUC6y9In2khQtkTn4aSBU
# Уровень логирования: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Количество повторных попыток при сбоях Telegram API.
TELEGRAM_RETRIES=3

# Пауза между попытками, в секундах.
TELEGRAM_RETRY_DELAY=1.5

# Путь к папке с данными внутри контейнера.
DATA_DIR=/app/data

# Путь к SQLite-файлу внутри контейнера.
SQLITE_DB_PATH=/app/data/bot.sqlite3